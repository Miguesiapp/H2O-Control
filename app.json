{
  "expo": {
    "name": "H2O Control Neural",
    "slug": "H2O-Control-Neural",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.migue.h2ocontrol",
      "infoPlist": {
        "NSCameraUsageDescription": "H2O Control necesita acceso a la cámara para el registro biométrico de asistencia."
      }
    },
    "android": {
      "package": "com.migue.h2ocontrol",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f172a"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Permitir que H2O Control Neural use la cámara para el presentismo biométrico.",
          "recordAudioPermission": false
        }
      ],
      "expo-print"
    ],
    "extra": {
      "eas": {
        "projectId": "f8b19d0e-dd0e-4857-bde6-703581c1be69"
      }
    },
    "owner": "migue.si"
  }
}